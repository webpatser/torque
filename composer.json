{
    "name": "webpatser/torque",
    "description": "Coroutine-based queue worker for Laravel — N jobs per process via PHP Fibers and Redis Streams",
    "keywords": ["laravel", "queue", "fibers", "coroutines", "redis-streams", "async", "fledge"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "illuminate/queue": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "revolt/event-loop": "^1.0",
        "livewire/flux": "^2.0",
        "webpatser/fledge-fiber": "^13.4"
    },
    "suggest": {},
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Webpatser\\Torque\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webpatser\\Torque\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webpatser\\Torque\\TorqueServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
